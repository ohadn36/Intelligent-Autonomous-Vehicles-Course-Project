<?xml version="1.0"?>
<launch>
  <!-- Full patrol demo: navigation stack + waypoint script -->
  <arg name="map_file" default="$(find summit_xl_autonomous_nav)/maps/summit_world.yaml"/>
  <arg name="scan_topic" default="scan"/>
  <arg name="start_sim" default="true"/>

  <include file="$(find summit_xl_autonomous_nav)/launch/summit_xl_navigation.launch">
    <arg name="map_file" value="$(arg map_file)"/>
    <arg name="scan_topic" value="$(arg scan_topic)"/>
    <arg name="start_sim" value="$(arg start_sim)"/>
  </include>

  <node pkg="summit_xl_autonomous_nav" type="waypoint_patrol.py" name="waypoint_patrol" output="screen"/>
</launch>
